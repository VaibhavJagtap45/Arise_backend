NODE_ENV=development
PORT=5000
# Comma-separated allowed web origins for PRODUCTION (e.g. https://app.example.com).
# In development, localhost and any private LAN IP (any port) are accepted automatically.
CLIENT_ORIGIN=http://localhost:8081
# MongoDB connection string — your MongoDB Atlas URL or a local instance.
DATABASE_URL=mongodb://localhost:27017/calorie-tracker
# Generate a strong secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-secret
