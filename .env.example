NODE_ENV=development
PORT=5000
# Comma-separated allowed web origins for PRODUCTION (e.g. https://app.example.com).
# In development, localhost and any private LAN IP (any port) are accepted automatically.
CLIENT_ORIGIN=http://localhost:8081
# MongoDB connection string — your MongoDB Atlas URL or a local instance.
DATABASE_URL=mongodb://localhost:27017/calorie-tracker
# REQUIRED in production — the server refuses to start if this is missing or left
# as a placeholder when NODE_ENV=production. Generate a strong secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-secret
# How long a login stays valid before the user must sign in again.
# Accepts zeit/ms strings like "12h", "7d", "30d". Defaults to 7d.
JWT_EXPIRES_IN=7d

# --- Request body size (optional) ---
# Default max JSON/urlencoded body. The profile-update route is allowed a larger
# limit (PROFILE_BODY_LIMIT) for base64 photos.
JSON_BODY_LIMIT=1mb
PROFILE_BODY_LIMIT=5mb

# --- Rate limiting (optional; sensible defaults applied when unset) ---
# Auth endpoints (login/register/forgot-password): default 10 requests / 15 min per IP.
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=10
# Food search/lookup: default 60 requests / 1 min per IP.
FOOD_RATE_WINDOW_MS=60000
FOOD_RATE_MAX=60
# Admin routes: default 100 requests / 15 min per IP.
ADMIN_RATE_WINDOW_MS=900000
ADMIN_RATE_MAX=100
